/* * MLB PORTFOLIO TRACKER DATABASE SCHEMA
 * ---------------------------------------------------------
 * This script sets up the core tables, views, functions, and 
 * triggers required for the Portfolio Tracker application.
 */

-- =========================================================
-- 1. EXTENSIONS
-- =========================================================

-- Enable cron for scheduling updates
CREATE EXTENSION IF NOT EXISTS pg_cron;

-- Enable net for HTTP calls (Edge Functions)
CREATE EXTENSION IF NOT EXISTS pg_net;


-- =========================================================
-- 2. CORE TABLES
-- =========================================================

-- 1. PROFILES (The Managers)
-- Links directly to Supabase Auth Users
CREATE TABLE profiles (
    id UUID PRIMARY KEY REFERENCES auth.users ON DELETE CASCADE,
    username TEXT UNIQUE NOT NULL,
    full_name TEXT,
    email TEXT UNIQUE NOT NULL,
    client_ids UUID[] DEFAULT '{}', -- List of clients owned by this profile
    screensaver_click_only BOOLEAN DEFAULT FALSE,
    admin_level INTEGER DEFAULT 0 CHECK (admin_level IN (0, 1, 2)), -- 0: No Admin, 1: Intermediate, 2: Superadmin
    auto_fold_sidebar BOOLEAN DEFAULT FALSE,
    theme_preference TEXT DEFAULT 'system',
    created_at TIMESTAMPTZ DEFAULT now()
);
COMMENT ON COLUMN profiles.admin_level IS 'Will the user get advanced controls. Manually set';

-- 2. CLIENTS (The Accounts)
-- Represents distinct portfolios or family members
CREATE TABLE clients (
    client_name TEXT PRIMARY KEY, -- Using name as PK as requested
    trading_id TEXT UNIQUE NOT NULL,
    client_id UUID UNIQUE DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES profiles(id) ON DELETE CASCADE,
    dp_id TEXT UNIQUE, -- Added DP ID for reporting
    last_verified TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- 3. ASSETS (The Master Catalog)
-- Stores market data and instrument details
CREATE TABLE assets (
    ticker TEXT PRIMARY KEY,
    stock_name TEXT NOT NULL,
    isin TEXT, -- Removed UNIQUE as requested
    current_price NUMERIC DEFAULT 0,
    cutoff DOUBLE PRECISION, -- Section 112A Baseline FMV Grandfathered Rate
    beta NUMERIC,
    trailing_pe NUMERIC,
    eps NUMERIC,
    today_high NUMERIC,
    today_low NUMERIC,
    today_open NUMERIC,
    fifty_two_week_high NUMERIC,
    fifty_two_week_low NUMERIC,
    market_cap BIGINT,
    avg_volume NUMERIC,
    market_volume NUMERIC,
    last_updated TIMESTAMPTZ DEFAULT now()
);

-- 4. PURCHASES (The "In" Ledger)
-- Log of all buy transactions
-- Date is expected in yyyy-mm-dd format
CREATE TABLE purchases (
    trx_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES profiles(id) NOT NULL,
    client_name TEXT REFERENCES clients(client_name) ON DELETE CASCADE,
    client_id UUID REFERENCES clients(client_id), -- Linked UUID for faster joins
    ticker TEXT REFERENCES assets(ticker),
    date DATE NOT NULL,
    rate NUMERIC NOT NULL,
    purchase_qty NUMERIC NOT NULL CHECK (purchase_qty > 0),
    balance_qty NUMERIC DEFAULT 0, -- Current quantity held
    comments TEXT,
    sale_ids UUID[] DEFAULT '{}', -- Array to track partial sales linked to this purchase
    created_at TIMESTAMPTZ DEFAULT now()
);

-- 5. SALES (The "Out" Ledger)
-- Log of all sell transactions
CREATE TABLE sales (
    trx_id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID,
    purchase_trx_id UUID REFERENCES purchases(trx_id) ON DELETE CASCADE,
    client_id UUID,
    client_name TEXT,
    date DATE NOT NULL,
    rate NUMERIC(20, 2) NOT NULL,
    sale_qty NUMERIC(20, 8) NOT NULL CHECK (sale_qty > 0),
    profit_stored NUMERIC,
    adjusted_profit_stored NUMERIC,
    long_term BOOLEAN,
    is_square_off BOOLEAN DEFAULT FALSE,
    custom_id TEXT,
    comments TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- 6. PLEDGES (The Pledge Ledger)
-- Ledger for Pledging/Unpledging Transactions
CREATE TABLE pledges (
    client_name TEXT REFERENCES clients(client_name) ON DELETE CASCADE,
    ticker TEXT REFERENCES assets(ticker),
    pledged_qty NUMERIC NOT NULL CHECK (pledged_qty >= 0),
    created_at TIMESTAMPTZ DEFAULT now(),
    PRIMARY KEY (client_name, ticker) 
);

-- 7. PRICE ALERTS (User Notifications)
-- User configured alerts to be triggered dynamically based on price or volume spikes
CREATE TYPE alert_condition AS ENUM ('greater_than', 'less_than', 'crossing_up', 'crossing_down', 'volume_spike', 'percentage_change_up', 'percentage_change_down');

CREATE TABLE price_alerts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES profiles(id) ON DELETE CASCADE,
    ticker TEXT REFERENCES assets(ticker) ON DELETE CASCADE,
    
    condition alert_condition NOT NULL,
    target_type TEXT NOT NULL, 
    target_value NUMERIC, 
    
    is_triggered BOOLEAN DEFAULT FALSE,
    is_active BOOLEAN DEFAULT TRUE,
    is_one_time BOOLEAN DEFAULT FALSE, 
    
    note TEXT, 
    expires_at TIMESTAMPTZ, 
    snoozed_until TIMESTAMPTZ,
    
    created_at TIMESTAMPTZ DEFAULT now()
);

-- =========================================================
-- 3. INDEXES & SEQUENCES
-- =========================================================

-- Performance index for querying purchases by specific sale IDs (GIN index for Arrays)
CREATE INDEX IF NOT EXISTS idx_purchases_sale_ids ON purchases USING GIN (sale_ids);

-- Performance index for client lookup in profiles (GIN index for Arrays)
CREATE INDEX IF NOT EXISTS idx_profiles_client_ids ON profiles USING GIN (client_ids);

-- Sequence for generating custom readable IDs if needed
CREATE SEQUENCE IF NOT EXISTS sale_group_seq START 1;
-- Command to check the current value of the sale_group_seq
SELECT last_value, is_called FROM sale_group_seq;
-- Command to reset the sale_group_seq to be 2
ALTER SEQUENCE sale_group_seq RESTART WITH 2;

-- =========================================================
-- 4. VIEWS
-- =========================================================

-- View: CLIENT HOLDINGS
-- Calculates live balance, market value, and unrealized P&L
CREATE OR REPLACE VIEW client_holdings AS
SELECT 
    -- IDs and Identifiers
    p.trx_id,
    c.client_id,
    c.client_name,
    c.dp_id,
    c.trading_id,
    a.ticker,
    a.stock_name,
    a.isin,

   (p.date <= (CURRENT_DATE - INTERVAL '1 year')) as long_term,
    
    -- Purchase Details
    p.date,
    p.purchase_qty,
    p.rate,
    (p.purchase_qty * p.rate) AS purchase_value,
    p.balance_qty,
    p.comments,

    -- Market Details
    a.current_price AS market_rate,
    a.beta,
    a.trailing_pe,
    a.eps,
    a.today_high,
    a.today_low,
    a.today_open,
    a.market_cap,
    a.fifty_two_week_high,
    a.fifty_two_week_low,
    a.market_volume,
    a.avg_volume,
    (p.balance_qty * a.current_price) AS market_value,

    -- Calculations
    (a.current_price - p.rate) AS pl_per_share,
    ((a.current_price - p.rate) * p.balance_qty) AS pl,
    CASE 
        WHEN p.rate > 0 THEN ((a.current_price - p.rate) / p.rate) * 100 
        ELSE 0 
    END AS pl_percent
FROM purchases p
JOIN assets a ON p.ticker = a.ticker
JOIN clients c ON p.client_name = c.client_name;

-- View: SALES VIEW
-- Denormalized view of sales with linked purchase info
CREATE OR REPLACE VIEW sales_view AS
SELECT 
    s.trx_id,
    c.client_id,
    c.trading_id,
    c.dp_id,
    s.client_name,
    p.ticker,
    a.stock_name,
    a.isin,
    p.date AS purchase_date,
    p.rate AS purchase_rate,
    p.trx_id as purchase_trx_id,
    p.purchase_qty,
    s.date AS sale_date,
    s.sale_qty,
    s.rate AS sale_rate,
    (s.sale_qty * p.rate) AS purchase_value,
    (s.sale_qty * s.rate) AS sale_value,
    s.profit_stored AS pl,
    ((s.profit_stored / p.rate) * 100) AS pl_percentage,
    s.adjusted_profit_stored AS adjusted_pl,
    s.long_term,
    s.is_square_off,
    s.comments,
    s.user_id,
    s.custom_id
FROM sales s
JOIN purchases p ON s.purchase_trx_id = p.trx_id
JOIN clients c ON p.client_name = c.client_name
JOIN assets a ON p.ticker = a.ticker;


-- =========================================================
-- 5. FUNCTIONS (BUSINESS LOGIC)
-- =========================================================

-- Function: Append Sale ID to Purchase
-- Updates the purchase record when a portion is sold
CREATE OR REPLACE FUNCTION append_sale_id_to_purchase(
    p_purchase_id UUID, 
    p_sale_id UUID, 
    p_new_balance NUMERIC
)
RETURNS void AS $$
BEGIN
    UPDATE purchases
    SET 
        balance_qty = p_new_balance,
        sale_ids = array_append(COALESCE(sale_ids, '{}'), p_sale_id)
    WHERE trx_id = p_purchase_id;
END;
$$ LANGUAGE plpgsql;

-- Function: Get Next Sale ID
-- Returns next value from sequence
CREATE OR REPLACE FUNCTION get_next_sale_id()
RETURNS BIGINT AS $$
BEGIN
  RETURN nextval('sale_group_seq');
END;
$$ LANGUAGE plpgsql;

-- Function: Bulk Asset Update
-- Purpose: Atomic upsert for assets. If ISIN exists but ticker changed, 
--          it cascades the update to purchases and pledges.
CREATE OR REPLACE FUNCTION bulk_asset_update(payload JSONB)
RETURNS VOID AS $$
DECLARE
    a_record JSONB;
BEGIN
    FOR a_record IN SELECT * FROM jsonb_array_elements(payload -> 'assets_to_upsert')
    LOOP
        INSERT INTO assets (
            ticker, stock_name, isin, current_price, beta, trailing_pe, 
            eps, today_open, today_high, today_low, market_cap, last_updated
        )
        VALUES (
            (a_record ->> 'ticker'),
            (a_record ->> 'stock_name'),
            (a_record ->> 'isin'),
            COALESCE((a_record ->> 'current_price')::NUMERIC, 0),
            (a_record ->> 'beta')::NUMERIC,
            (a_record ->> 'trailing_pe')::NUMERIC,
            (a_record ->> 'eps')::NUMERIC,
            (a_record ->> 'today_open')::NUMERIC,
            (a_record ->> 'today_high')::NUMERIC,
            (a_record ->> 'today_low')::NUMERIC,
            (a_record ->> 'market_cap')::BIGINT,
            now()
        )
        ON CONFLICT (ticker) 
        DO UPDATE SET 
            isin = EXCLUDED.isin,
            stock_name = EXCLUDED.stock_name,
            current_price = CASE WHEN EXCLUDED.current_price > 0 THEN EXCLUDED.current_price ELSE assets.current_price END,
            beta = EXCLUDED.beta,
            trailing_pe = EXCLUDED.trailing_pe,
            eps = EXCLUDED.eps,
            today_open = EXCLUDED.today_open,
            today_high = EXCLUDED.today_high,
            today_low = EXCLUDED.today_low,
            market_cap = EXCLUDED.market_cap,
            last_updated = now();
    END LOOP;
END;
$$ LANGUAGE plpgsql;

-- Function: Atomic Ledger Update
-- Purpose: Handles complex transaction edits in a single transaction.
--          1. Deletes old sales (splits) if re-processing is needed.
--          2. Updates purchase records (balance, linkage, and core details).
--          3. Inserts new recalculated sale records.
-- Input:   JSONB object with optional keys: 'sales_to_delete', 'purchases_to_update', 'sales_to_insert'.

CREATE OR REPLACE FUNCTION atomic_ledger_update(payload JSONB)
RETURNS VOID AS $$
DECLARE
    p_record JSONB;
    s_record JSONB;
    p_insert JSONB;
    id_to_delete TEXT;
BEGIN
    -- 0. INSERT New Purchases
    -- This handles bulk importing purchase transactions.
    IF payload ? 'purchases_to_insert' THEN
            INSERT INTO purchases (
            user_id,
            client_name,
            ticker,
            date,
            rate,
            purchase_qty,
            balance_qty,
            comments
        )
        SELECT 
            (value ->> 'user_id')::UUID,
            (value ->> 'client_name'),
            (value ->> 'ticker'),
            (value ->> 'date')::DATE,
            (value ->> 'rate')::NUMERIC,
            (value ->> 'purchase_qty')::NUMERIC,
            (value ->> 'balance_qty')::NUMERIC,
            (value ->> 'comments')
        FROM jsonb_array_elements(payload -> 'purchases_to_insert');
    END IF;

    -- 1. DELETE Old Sales (Splits)
    -- Expects an array of 'trx_id' UUIDs to remove specific sale splits.
    IF payload ? 'sales_to_delete' THEN
        FOR id_to_delete IN SELECT jsonb_array_elements_text(payload -> 'sales_to_delete')
        LOOP
            DELETE FROM sales WHERE trx_id = id_to_delete::UUID;
        END LOOP;
    END IF;

    -- 2. UPDATE Purchases
    -- Updates inventory balance/linkage AND core editable fields.
    IF payload ? 'purchases_to_update' THEN
        FOR p_record IN SELECT * FROM jsonb_array_elements(payload -> 'purchases_to_update')
        LOOP
            UPDATE purchases 
            SET 
                -- Inventory Management
                balance_qty = (p_record ->> 'balance_qty')::NUMERIC,
                sale_ids = ARRAY(SELECT jsonb_array_elements_text(p_record -> 'sale_ids')::UUID),
                
                -- Core Editable Fields
                date         = (p_record ->> 'date')::DATE,
                purchase_qty = (p_record ->> 'purchase_qty')::NUMERIC,
                rate         = (p_record ->> 'rate')::NUMERIC,
                comments     = (p_record ->> 'comments')
            WHERE trx_id = (p_record ->> 'trx_id')::UUID;
        END LOOP;
    END IF;

    -- 3. INSERT New Sales
    -- Inserts re-calculated sale splits.
    IF payload ? 'sales_to_insert' THEN
        INSERT INTO sales (
            trx_id, 
            custom_id, 
            purchase_trx_id, 
            client_name, 
            client_id,    
            date, 
            sale_qty, 
            rate, 
            profit_stored, 
            adjusted_profit_stored,
            long_term,
            is_square_off,
            user_id,
            comments
        )
        SELECT 
            (value ->> 'trx_id')::UUID,
            (value ->> 'custom_id'),
            (value ->> 'purchase_trx_id')::UUID,
            (value ->> 'client_name'),
            (value ->> 'client_id')::UUID,
            (value ->> 'date')::DATE,
            (value ->> 'sale_qty')::NUMERIC, 
            (value ->> 'rate')::NUMERIC,
            (value ->> 'profit_stored')::NUMERIC,
            (value ->> 'adjusted_profit_stored')::NUMERIC,
            (value ->> 'long_term')::BOOLEAN,
            (value ->> 'is_square_off')::BOOLEAN,
            (value ->> 'user_id')::UUID,
            (value ->> 'comments')
        FROM jsonb_array_elements(payload -> 'sales_to_insert');
    END IF;

    -- 4. UPDATE Existing Sales
    -- This handles re-calculating profit or updating details for specific sales
    IF payload ? 'sales_to_update' THEN
        FOR s_record IN SELECT * FROM jsonb_array_elements(payload -> 'sales_to_update')
        LOOP
            UPDATE sales 
            SET 
                profit_stored          = (s_record ->> 'profit_stored')::NUMERIC,
                adjusted_profit_stored = (s_record ->> 'adjusted_profit_stored')::NUMERIC,
                rate                   = (s_record ->> 'rate')::NUMERIC,
                sale_qty               = (s_record ->> 'sale_qty')::NUMERIC,
                date                   = (s_record ->> 'date')::DATE,
                is_square_off          = (s_record ->> 'is_square_off')::BOOLEAN,
                comments               = (s_record ->> 'comments')
            WHERE trx_id = (s_record ->> 'trx_id')::UUID;
        END LOOP;
    END IF;
END;
$$ LANGUAGE plpgsql;

-- Function: Migrate BSE to NSE Tickers
-- Purpose: Automatically replaces BSE tickers (numeric) with NSE equivalents (alphanumeric) 
--          based on ISIN matching for all currently held positions.
-- Logic:   1. Identifies unique BSE tickers in current holdings.
--          2. Finds NSE ticker with same ISIN in assets table.
--          3. Updates purchases and merges pledges.
CREATE OR REPLACE FUNCTION migrate_bse_to_nse()
RETURNS void AS $$
DECLARE
    r RECORD;
    v_nse_ticker TEXT;
BEGIN
    FOR r IN (
        SELECT DISTINCT ticker, isin
        FROM client_holdings
        WHERE ticker ~ '^[0-9]+$'
    ) LOOP
        SELECT ticker INTO v_nse_ticker
        FROM assets
        WHERE isin = r.isin
          AND ticker ~ '[A-Za-z]'
        LIMIT 1;

        IF v_nse_ticker IS NOT NULL THEN
            UPDATE purchases 
            SET ticker = v_nse_ticker 
            WHERE ticker = r.ticker;

            INSERT INTO pledges (client_name, ticker, pledged_qty, created_at)
            SELECT client_name, v_nse_ticker, pledged_qty, now()
            FROM pledges
            WHERE ticker = r.ticker
            ON CONFLICT (client_name, ticker)
            DO UPDATE SET pledged_qty = pledges.pledged_qty + EXCLUDED.pledged_qty;

            DELETE FROM pledges WHERE ticker = r.ticker;
        END IF;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


-- Function: Reset Client Ledger
-- Purpose: Resets the entire trading ledger for a specific client by clearing all sales and resetting purchase balances.
-- Logic:   1. Updates the purchases table to set balance_qty back to original purchase_qty and clears sale_ids.
--          2. Deletes all records from the sales table for that client.
CREATE OR REPLACE FUNCTION reset_client_ledger(p_client_name TEXT) 
RETURNS VOID AS $$
BEGIN
    -- 1. Reset balances and clear sale links in the purchases table for the client
    UPDATE purchases 
    SET 
        balance_qty = purchase_qty,
        sale_ids = '{}'
    WHERE client_name = p_client_name;
    -- 2. Delete the actual sales records for the client
    DELETE FROM sales 
    WHERE client_name = p_client_name;
    RAISE NOTICE 'Ledger reset successfully for client: %', p_client_name;
END;
$$ LANGUAGE plpgsql;


-- Function: Update Assets from Google Sheet
-- Purpose: Bulk updates market data from a JSON payload while ignoring identity fields (#N/A or blanks).
-- Input:   JSONB array of asset objects.
CREATE OR REPLACE FUNCTION update_assets_from_sheet(payload JSONB)
RETURNS VOID AS $$
DECLARE
    a_record JSONB;
BEGIN
    FOR a_record IN SELECT * FROM jsonb_array_elements(payload)
    LOOP
        -- Update only if ticker exists
        UPDATE assets
        SET 
            current_price = CASE 
                WHEN (a_record ->> 'current_price') IS NULL 
                     OR TRIM(a_record ->> 'current_price') = '' 
                     OR (a_record ->> 'current_price') = '#N/A' 
                THEN current_price 
                ELSE (a_record ->> 'current_price')::NUMERIC 
            END,
            beta = CASE 
                WHEN (a_record ->> 'beta') IS NULL 
                     OR TRIM(a_record ->> 'beta') = '' 
                     OR (a_record ->> 'beta') = '#N/A' 
                THEN beta 
                ELSE (a_record ->> 'beta')::NUMERIC 
            END,
            trailing_pe = CASE 
                WHEN (a_record ->> 'trailing_pe') IS NULL 
                     OR TRIM(a_record ->> 'trailing_pe') = '' 
                     OR (a_record ->> 'trailing_pe') = '#N/A' 
                THEN trailing_pe 
                ELSE (a_record ->> 'trailing_pe')::NUMERIC 
            END,
            eps = CASE 
                WHEN (a_record ->> 'eps') IS NULL 
                     OR TRIM(a_record ->> 'eps') = '' 
                     OR (a_record ->> 'eps') = '#N/A' 
                THEN eps 
                ELSE (a_record ->> 'eps')::NUMERIC 
            END,
            today_high = CASE 
                WHEN (a_record ->> 'today_high') IS NULL 
                     OR TRIM(a_record ->> 'today_high') = '' 
                     OR (a_record ->> 'today_high') = '#N/A' 
                THEN today_high 
                ELSE (a_record ->> 'today_high')::NUMERIC 
            END,
            today_low = CASE 
                WHEN (a_record ->> 'today_low') IS NULL 
                     OR TRIM(a_record ->> 'today_low') = '' 
                     OR (a_record ->> 'today_low') = '#N/A' 
                THEN today_low 
                ELSE (a_record ->> 'today_low')::NUMERIC 
            END,
            today_open = CASE 
                WHEN (a_record ->> 'today_open') IS NULL 
                     OR TRIM(a_record ->> 'today_open') = '' 
                     OR (a_record ->> 'today_open') = '#N/A' 
                THEN today_open 
                ELSE (a_record ->> 'today_open')::NUMERIC 
            END,
            fifty_two_week_high = CASE 
                WHEN (a_record ->> 'fifty_two_week_high') IS NULL 
                     OR TRIM(a_record ->> 'fifty_two_week_high') = '' 
                     OR (a_record ->> 'fifty_two_week_high') = '#N/A' 
                THEN fifty_two_week_high 
                ELSE (a_record ->> 'fifty_two_week_high')::NUMERIC 
            END,
            fifty_two_week_low = CASE 
                WHEN (a_record ->> 'fifty_two_week_low') IS NULL 
                     OR TRIM(a_record ->> 'fifty_two_week_low') = '' 
                     OR (a_record ->> 'fifty_two_week_low') = '#N/A' 
                THEN fifty_two_week_low 
                ELSE (a_record ->> 'fifty_two_week_low')::NUMERIC 
            END,
            market_cap = CASE 
                WHEN (a_record ->> 'market_cap') IS NULL 
                     OR TRIM(a_record ->> 'market_cap') = '' 
                     OR (a_record ->> 'market_cap') = '#N/A' 
                THEN market_cap 
                ELSE (a_record ->> 'market_cap')::BIGINT 
            END,
            avg_volume = CASE 
                WHEN (a_record ->> 'avg_volume') IS NULL 
                     OR TRIM(a_record ->> 'avg_volume') = '' 
                     OR (a_record ->> 'avg_volume') = '#N/A' 
                THEN avg_volume 
                ELSE (a_record ->> 'avg_volume')::NUMERIC 
            END,
            market_volume = CASE 
                WHEN (a_record ->> 'market_volume') IS NULL 
                     OR TRIM(a_record ->> 'market_volume') = '' 
                     OR (a_record ->> 'market_volume') = '#N/A' 
                THEN market_volume 
                ELSE (a_record ->> 'market_volume')::NUMERIC 
            END,
            last_updated = now()
        WHERE ticker = UPPER(a_record ->> 'ticker');
    END LOOP;
END;
$$ LANGUAGE plpgsql;


