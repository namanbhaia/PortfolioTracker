-- 7. UPDATE ASSETS TABLE FROM PURCHASE SHEET TICKERS
-- Created TABLE temp_updates with ticker and current_price from purchase
-- =========================================================


WITH deduplicated_csv AS (
  -- This picks exactly ONE row per ticker from your temp table
  SELECT DISTINCT ON (ticker) 
    ticker, 
    current_price
  FROM temp_updates
  ORDER BY ticker, current_price DESC -- If duplicates exist, it picks the highest price
)
UPDATE assets
SET 
  current_price = deduplicated_csv.current_price,
  last_updated = NOW()
FROM deduplicated_csv
WHERE assets.ticker = deduplicated_csv.ticker;
